{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "esbuild"],
      "cwd": "${workspaceFolder}/extension",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: watch extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "cwd": "${workspaceFolder}/extension",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*watch.*",
          "endsPattern": "^.*initial build complete.*"
        }
      }
    }
  ]
}
